rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Phase 0: Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitive Definition
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null && request.auth.token.email_verified == true; }
    
    // The "Master Gate" (Relational Sync)
    function isTeamMember(teamId) {
      return exists(/databases/$(database)/documents/teams/$(teamId)/members/$(request.auth.uid));
    }

    // Phase 2: Validation Blueprints (The "Anti-Update-Gap")
    function isValidTeamMember(data, userId) {
      return data.keys().hasAll(['uid', 'joinedAt']) && data.keys().size() == 2
        && data.uid is string && data.uid.size() > 0 && data.uid.size() <= 128
        && data.uid == request.auth.uid
        && data.joinedAt is timestamp;
    }

    function isValidSetting(data) {
      return data.keys().hasAny(['roster', 'savedRosters', 'savedLineups'])
        && (!('roster' in data) || data.roster is list && data.roster.size() <= 50)
        && (!('savedRosters' in data) || data.savedRosters is map)
        && (!('savedLineups' in data) || data.savedLineups is map);
    }

    function isValidOpponent(data) {
      return data.keys().hasAny(['defaultLineup', 'notes', 'setterId', 'liberoId'])
        && (!('defaultLineup' in data) || data.defaultLineup is list && data.defaultLineup.size() <= 20)
        && (!('notes' in data) || data.notes is map)
        // allow string or null equivalent for setterId
        && (!('setterId' in data) || data.setterId == null || (data.setterId is string && data.setterId.size() <= 128))
        && (!('liberoId' in data) || data.liberoId == null || (data.liberoId is string && data.liberoId.size() <= 128));
    }

    function isValidMatch(data) {
      return data.keys().hasAll(['id', 'date', 'type', 'opponent', 'format'])
        && data.id is string && data.id.size() <= 128
        && data.date is string && data.date.size() <= 64
        && data.type is string && data.type.size() <= 64
        && data.opponent is string && data.opponent.size() <= 128
        && data.format is string && data.format.size() <= 64
        && (!('title' in data) || data.title is string && data.title.size() <= 256)
        && (!('cap' in data) || data.cap is string && data.cap.size() <= 64);
    }

    function isValidSet(data) {
      return data.keys().hasAll(['id', 'matchId', 'setNum', 'scoreUcc', 'scoreOpp'])
        && data.id is string && data.id.size() <= 128
        && data.matchId is string && data.matchId.size() <= 128
        && data.setNum is number
        && data.scoreUcc is number
        && data.scoreOpp is number;
    }

    function isValidStat(data) {
      return data.keys().hasAll(['id', 'matchId', 'setId', 'playerId', 'category', 'metric', 'timestamp'])
        && data.id is string && data.id.size() <= 128
        && data.matchId is string && data.matchId.size() <= 128
        && data.setId is string && data.setId.size() <= 128
        && data.playerId is string && data.playerId.size() <= 128
        && data.category is string && data.category.size() <= 128
        && data.metric is string && data.metric.size() <= 128
        && data.timestamp is string && data.timestamp.size() <= 64
        && (!('value' in data) || data.value is number)
        && (!('isOpponent' in data) || data.isOpponent is bool);
    }

    // Path Variable Hardening
    match /teams/{teamId} {

      match /members/{userId} {
        allow get: if isSignedIn() && isTeamMember(teamId);
        allow list: if isSignedIn() && isTeamMember(teamId) && existing().uid != null;
        allow create: if isSignedIn() 
          && isValidId(teamId) 
          && isValidId(userId)
          && request.auth.uid == userId
          && isValidTeamMember(incoming(), userId)
          && incoming().joinedAt == request.time;
        allow update: if false; // immutable
        allow delete: if isSignedIn() && request.auth.uid == userId;
      }

      match /settings/{settingId} {
        allow get: if isSignedIn() && isTeamMember(teamId) && isValidId(teamId) && isValidId(settingId);
        allow list: if isSignedIn() && isTeamMember(teamId) && isValidId(teamId);
        allow create: if isSignedIn() && isTeamMember(teamId) && isValidId(teamId) && isValidId(settingId)
          && isValidSetting(incoming());
        allow update: if isSignedIn() && isTeamMember(teamId) && isValidId(teamId) && isValidId(settingId)
          && isValidSetting(incoming());
        allow delete: if false;
      }

      match /opponents/{opponentId} {
        allow get: if isSignedIn() && isTeamMember(teamId) && isValidId(teamId) && isValidId(opponentId);
        allow list: if isSignedIn() && isTeamMember(teamId) && isValidId(teamId);
        allow create: if isSignedIn() && isTeamMember(teamId) && isValidId(teamId) && isValidId(opponentId)
          && isValidOpponent(incoming());
        allow update: if isSignedIn() && isTeamMember(teamId) && isValidId(teamId) && isValidId(opponentId)
          && isValidOpponent(incoming());
        allow delete: if isSignedIn() && isTeamMember(teamId) && isValidId(teamId) && isValidId(opponentId);
      }

      match /matches/{matchId} {
        allow get: if isSignedIn() && isTeamMember(teamId) && isValidId(teamId) && isValidId(matchId);
        allow list: if isSignedIn() && isTeamMember(teamId) && isValidId(teamId);
        allow create: if isSignedIn() && isTeamMember(teamId) && isValidId(teamId) && isValidId(matchId)
          && isValidMatch(incoming());
        allow update: if isSignedIn() && isTeamMember(teamId) && isValidId(teamId) && isValidId(matchId)
          && isValidMatch(incoming());
        allow delete: if isSignedIn() && isTeamMember(teamId) && isValidId(teamId) && isValidId(matchId);
      }

      match /sets/{setId} {
        allow get: if isSignedIn() && isTeamMember(teamId) && isValidId(teamId) && isValidId(setId);
        allow list: if isSignedIn() && isTeamMember(teamId) && isValidId(teamId);
        allow create: if isSignedIn() && isTeamMember(teamId) && isValidId(teamId) && isValidId(setId)
          && isValidSet(incoming());
        allow update: if isSignedIn() && isTeamMember(teamId) && isValidId(teamId) && isValidId(setId)
          && isValidSet(incoming())
          && incoming().matchId == existing().matchId
          && incoming().setNum == existing().setNum;
        allow delete: if isSignedIn() && isTeamMember(teamId) && isValidId(teamId) && isValidId(setId);
      }

      match /stats/{statId} {
        allow get: if isSignedIn() && isTeamMember(teamId) && isValidId(teamId) && isValidId(statId);
        allow list: if isSignedIn() && isTeamMember(teamId) && isValidId(teamId);
        allow create: if isSignedIn() && isTeamMember(teamId) && isValidId(teamId) && isValidId(statId)
          && isValidStat(incoming());
        allow update: if false; // stats shouldn't be updated, just created or deleted
        allow delete: if isSignedIn() && isTeamMember(teamId) && isValidId(teamId) && isValidId(statId);
      }
    }
  }
}
